{
  "name": "tiptap-content-kit",
  "version": "0.3.7",
  "description": "Full-featured Tiptap editor with rich toolbar, table controls, AI assistant, special blocks, i18n, and content parsers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiotemple/tiptap-content-kit.git"
  },
  "homepage": "https://github.com/studiotemple/tiptap-content-kit#readme",
  "bugs": {
    "url": "https://github.com/studiotemple/tiptap-content-kit/issues"
  },
  "keywords": ["tiptap", "editor", "rich-text", "react", "vue", "i18n", "ai", "markdown", "content-kit"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./parsers": {
      "types": "./dist/parsers.d.ts",
      "import": "./dist/parsers.js",
      "require": "./dist/parsers.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "require": "./dist/schema.cjs"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.js",
      "require": "./dist/extensions.cjs"
    },
    "./extensions-vue": {
      "types": "./dist/extensions-vue.d.ts",
      "import": "./dist/extensions-vue.js",
      "require": "./dist/extensions-vue.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js",
      "require": "./dist/providers.cjs"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.js",
      "require": "./dist/editor.cjs"
    },
    "./editor/style.css": "./dist/editor.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.20.1",
    "cheerio": "^1.0.0",
    "entities": "^6.0.0",
    "lowlight": "^3.3.0",
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "@tiptap/core": ">=2.0.0",
    "@tiptap/extension-image": ">=2.0.0",
    "@tiptap/extension-link": ">=2.0.0",
    "@tiptap/extension-placeholder": ">=2.0.0",
    "@tiptap/extension-table": ">=2.0.0",
    "@tiptap/extension-table-cell": ">=2.0.0",
    "@tiptap/extension-table-header": ">=2.0.0",
    "@tiptap/extension-table-row": ">=2.0.0",
    "@tiptap/extension-task-item": ">=2.0.0",
    "@tiptap/extension-code-block-lowlight": ">=2.0.0",
    "@tiptap/extension-task-list": ">=2.0.0",
    "@tiptap/extension-text-align": ">=2.0.0",
    "@tiptap/extension-underline": ">=2.0.0",
    "@tiptap/react": ">=2.0.0",
    "@tiptap/starter-kit": ">=2.0.0",
    "@tiptap/vue-3": ">=2.0.0",
    "mammoth": ">=1.0.0",
    "mermaid": ">=10.0.0",
    "pdf-parse": ">=2.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vue": ">=3.0.0",
    "word-extractor": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
